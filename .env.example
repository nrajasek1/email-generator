# =============================================================================
# Email Generator — environment variables
# =============================================================================
# Copy this file to `.env` and fill in ONE of the API keys below.
#   cp .env.example .env
#
# The app will refuse to start a generation request without a key.
# =============================================================================

# -----------------------------------------------------------------------------
# Provider selection
# -----------------------------------------------------------------------------
# auto       — prefer OpenRouter when OPENROUTER_API_KEY is set, else OpenAI
# openrouter — force OpenRouter (requires OPENROUTER_API_KEY)
# openai     — force OpenAI (requires OPENAI_API_KEY)
LLM_PROVIDER=auto

# -----------------------------------------------------------------------------
# OpenRouter (recommended — has a free tier)
#   Get a key: https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# -----------------------------------------------------------------------------
# OpenAI (alternative — paid)
#   Get a key: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_REASONING_EFFORT=none

# -----------------------------------------------------------------------------
# Generation tuning (optional — defaults shown)
# -----------------------------------------------------------------------------
MAX_OUTPUT_TOKENS=800
